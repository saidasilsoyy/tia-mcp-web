APP_NAME="TIA MCP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tiamcp.com
APP_VERSION=1.0.0
APP_TIMEZONE=Europe/Istanbul
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=HOSTINGER_DATABASE_NAME
DB_USERNAME=HOSTINGER_DATABASE_USER
DB_PASSWORD=HOSTINGER_DATABASE_PASSWORD

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
CACHE_PREFIX=tiamcp

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=support@tiamcp.com
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

TIAMCP_API_VERSION=v1
TIAMCP_DEPLOYMENT_LABEL=hostinger-production
TIAMCP_PUBLIC_API_BASE_URL="${APP_URL}/api/v1"
TIAMCP_DEVICE_ACTIVATION_URL="${APP_URL}/device"
TIAMCP_SUPPORT_EMAIL=support@tiamcp.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

GITHUB_LOGIN_CLIENT_ID=
GITHUB_LOGIN_CLIENT_SECRET=
GITHUB_LOGIN_REDIRECT_URI="${APP_URL}/auth/github/callback"

GITHUB_PRODUCT_CLIENT_ID=
GITHUB_PRODUCT_CLIENT_SECRET=
GITHUB_PRODUCT_REDIRECT_URI="${APP_URL}/account/github/callback"

ENTITLEMENT_SIGNING_KEY_ID=hostinger-production
ENTITLEMENT_SIGNING_SECRET=GENERATE_WITH_RANDOM_BASE64_SECRET
ENTITLEMENT_SIGNING_PRIVATE_KEY_PATH=
ENTITLEMENT_SIGNING_PUBLIC_KEY_PATH=
ENTITLEMENT_SIGNING_ALG=HS256
ENTITLEMENT_OFFLINE_WINDOW_MINUTES=1440

DEVICE_AUTHORIZATION_EXPIRES_MINUTES=10
DEVICE_POLL_INTERVAL_SECONDS=5
DEVICE_ACCESS_TOKEN_TTL_MINUTES=60
DEVICE_REFRESH_TOKEN_TTL_DAYS=90

SANCTUM_STATEFUL_DOMAINS=tiamcp.com,www.tiamcp.com
